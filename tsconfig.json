{
  "exclude": ["node_modules", "dist"],
  "include": ["src/**/*.ts"],
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",

    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true,

    "types": ["node"]
  }
}
